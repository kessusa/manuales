"""
Additional views for ZIP downloads.

Append these to your existing rss/views.py.

Two endpoints:
    - download_folder_zip(folder_id): zip an entire folder (recursive)
    - download_files_zip(): zip a list of selected files (POST with file_ids)
"""
import io
import zipfile

from django.contrib.auth.decorators import login_required
from django.core.exceptions import PermissionDenied
from django.http import HttpResponse, JsonResponse
from django.shortcuts import get_object_or_404
from django.utils.text import slugify
from django.views.decorators.http import require_POST

from filer.models import File, Folder

# These helpers already exist in your views.py:
# from .views import _has_permission


def _add_file_to_zip(zip_file, file_obj, archive_path):
    """Add a single filer File to the open ZipFile under the given archive path."""
    try:
        with file_obj.file.open('rb') as fh:
            zip_file.writestr(archive_path, fh.read())
    except Exception:
        # Skip unreadable files silently; you can log them if needed
        pass


def _walk_folder(folder, current_path=''):
    """
    Yield (file_obj, archive_path) tuples for every file inside `folder`,
    recursively. `archive_path` is the relative path inside the resulting ZIP.
    """
    for f in folder.files.all():
        name = f.name or f.original_filename
        archive_path = f'{current_path}/{name}' if current_path else name
        yield f, archive_path

    for child in folder.children.all():
        sub_path = f'{current_path}/{child.name}' if current_path else child.name
        yield from _walk_folder(child, sub_path)


@login_required
def download_folder_zip(request, folder_id):
    """
    Stream a ZIP archive containing the entire content of a folder
    (files and nested subfolders), preserving the folder structure.
    """
    folder = get_object_or_404(Folder, id=folder_id)
    if not _has_permission(request.user, folder, 'can_read'):
        raise PermissionDenied('You do not have permission to read this folder.')

    # Build the ZIP in memory. For very large folders consider streaming
    # with django-zip-stream or writing to a temporary file on disk.
    buffer = io.BytesIO()
    with zipfile.ZipFile(buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
        for file_obj, archive_path in _walk_folder(folder):
            # Skip files inside subfolders the user cannot read
            if file_obj.folder and not _has_permission(request.user, file_obj.folder, 'can_read'):
                continue
            _add_file_to_zip(zf, file_obj, archive_path)

    buffer.seek(0)
    zip_name = f'{slugify(folder.name) or "folder"}.zip'

    response = HttpResponse(buffer.getvalue(), content_type='application/zip')
    response['Content-Disposition'] = f'attachment; filename="{zip_name}"'
    return response


@login_required
@require_POST
def download_files_zip(request):
    """
    Stream a ZIP containing a selection of files. Expects a POST with one or
    more `file_ids` (multiple values, e.g. from checkboxes).
    """
    file_ids = request.POST.getlist('file_ids')
    if not file_ids:
        return JsonResponse({'status': False, 'message': 'No files selected.'})

    files = File.objects.filter(id__in=file_ids)

    # Permission check: user must be able to read every selected file's folder
    for f in files:
        if f.folder and not _has_permission(request.user, f.folder, 'can_read'):
            raise PermissionDenied('You do not have permission to read one of the selected files.')

    if not files:
        return JsonResponse({'status': False, 'message': 'No matching files found.'})

    buffer = io.BytesIO()
    with zipfile.ZipFile(buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
        for f in files:
            name = f.name or f.original_filename
            _add_file_to_zip(zf, f, name)

    buffer.seek(0)
    response = HttpResponse(buffer.getvalue(), content_type='application/zip')
    response['Content-Disposition'] = 'attachment; filename="selection.zip"'
    return response

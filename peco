"""
Management command to manage django-filer folder permissions in bulk.

Location in project: rss/management/commands/manage_filer_permissions.py

Make sure these empty files exist:
    rss/management/__init__.py
    rss/management/commands/__init__.py

Usage examples:

  # Grant a user read access to a folder (and all subfolders, recursive)
  python manage.py manage_filer_permissions grant ^
      --folder "Firewall APAC Rules" ^
      --user jdoe ^
      --can-read ^
      --scope all

  # Grant a group read+edit access to a single folder
  python manage.py manage_filer_permissions grant ^
      --folder "Reports/2026" ^
      --group network_admins ^
      --can-read --can-edit ^
      --scope this

  # Grant everybody read access on the whole tree under a folder
  python manage.py manage_filer_permissions grant ^
      --folder "Public Reports" ^
      --everybody ^
      --can-read ^
      --scope all

  # Explicitly DENY a user
  python manage.py manage_filer_permissions deny ^
      --folder "Confidential" ^
      --user external_user ^
      --can-read --can-edit --can-add-children ^
      --scope all

  # List all permissions on a folder
  python manage.py manage_filer_permissions list --folder "Firewall APAC Rules"

  # Clear all permissions from a folder
  python manage.py manage_filer_permissions clear --folder "Firewall APAC Rules"
"""
from django.contrib.auth.models import Group
from django.core.management.base import BaseCommand, CommandError

from filer.models import Folder, FolderPermission

from accounts.models import User


class Command(BaseCommand):
    help = 'Manage django-filer folder permissions from the command line.'

    SCOPE_MAP = {
        'this': FolderPermission.THIS,
        'children': FolderPermission.CHILDREN,
        'all': FolderPermission.ALL,
    }

    def add_arguments(self, parser):
        parser.add_argument(
            'action',
            choices=['grant', 'deny', 'list', 'clear'],
            help='Action to perform.',
        )
        parser.add_argument(
            '--folder',
            type=str,
            required=True,
            help='Folder path inside filer, e.g. "Reports/2026". Missing folders are NOT created.',
        )

        # Target identification (mutually exclusive in practice)
        parser.add_argument('--user', type=str, help='Target user (looked up by user_uid).')
        parser.add_argument('--group', type=str, help='Target group name.')
        parser.add_argument('--everybody', action='store_true', help='Apply permission to everybody.')

        # Permission flags
        parser.add_argument('--can-read', action='store_true', help='Grant/deny read.')
        parser.add_argument('--can-edit', action='store_true', help='Grant/deny edit.')
        parser.add_argument(
            '--can-add-children',
            action='store_true',
            help='Grant/deny adding children.',
        )

        # Scope
        parser.add_argument(
            '--scope',
            choices=['this', 'children', 'all'],
            default='this',
            help='Permission scope (default: this).',
        )

    def handle(self, *args, **options):
        action = options['action']
        folder_path = options['folder']

        folder = self._resolve_folder(folder_path)

        if action == 'list':
            self._list_permissions(folder)
            return

        if action == 'clear':
            self._clear_permissions(folder)
            return

        # grant / deny
        target = self._resolve_target(options)
        permission_value = (
            FolderPermission.ALLOW if action == 'grant' else FolderPermission.DENY
        )

        # Build the permission flags. If a flag is omitted, leave it as None
        # (no opinion), which filer interprets as "inherit / not set".
        perm_kwargs = {
            'folder': folder,
            'type': self.SCOPE_MAP[options['scope']],
        }

        if options['can_read']:
            perm_kwargs['can_read'] = permission_value
        if options['can_edit']:
            perm_kwargs['can_edit'] = permission_value
        if options['can_add_children']:
            perm_kwargs['can_add_children'] = permission_value

        if not any(k in perm_kwargs for k in ('can_read', 'can_edit', 'can_add_children')):
            raise CommandError(
                'You must pass at least one of --can-read, --can-edit, --can-add-children.'
            )

        # Attach the target to the permission
        perm_kwargs.update(target)

        perm = FolderPermission.objects.create(**perm_kwargs)
        self.stdout.write(self.style.SUCCESS(
            f'{action.capitalize()}ed permission #{perm.id} on "{folder_path}".'
        ))

    # -----------------------------------------------------------------------
    # Helpers
    # -----------------------------------------------------------------------

    @staticmethod
    def _resolve_folder(folder_path):
        """Resolve a "/"-separated folder path. Does NOT create missing folders."""
        parts = [p.strip() for p in folder_path.split('/') if p.strip()]
        if not parts:
            raise CommandError('Folder path cannot be empty.')

        parent = None
        for part in parts:
            try:
                parent = Folder.objects.get(name=part, parent=parent)
            except Folder.DoesNotExist:
                raise CommandError(f'Folder "{part}" does not exist under the given path.')
        return parent

    @staticmethod
    def _resolve_target(options):
        """Return a dict that can be passed as kwargs to FolderPermission()."""
        targets_specified = sum(
            1 for k in ('user', 'group') if options.get(k)
        ) + (1 if options['everybody'] else 0)

        if targets_specified != 1:
            raise CommandError(
                'You must specify exactly one of --user, --group or --everybody.'
            )

        if options['user']:
            try:
                user = User.objects.get(user_uid=options['user'])
            except User.DoesNotExist:
                raise CommandError(f'User "{options["user"]}" not found.')
            return {'user': user}

        if options['group']:
            try:
                group = Group.objects.get(name=options['group'])
            except Group.DoesNotExist:
                raise CommandError(f'Group "{options["group"]}" not found.')
            return {'group': group}

        return {'everybody': True}

    def _list_permissions(self, folder):
        """Print all permissions defined on a folder."""
        perms = FolderPermission.objects.filter(folder=folder).select_related('user', 'group')
        if not perms:
            self.stdout.write(f'No permissions defined on "{folder.name}".')
            return

        self.stdout.write(f'Permissions on "{folder.name}":')
        self.stdout.write('-' * 90)
        self.stdout.write(
            f'{"ID":>4} | {"Target":<30} | {"Scope":<10} | '
            f'{"Read":<6} | {"Edit":<6} | {"Add":<6}'
        )
        self.stdout.write('-' * 90)
        for p in perms:
            if p.everybody:
                target = 'EVERYBODY'
            elif p.user:
                target = f'user: {p.user.user_uid}'
            elif p.group:
                target = f'group: {p.group.name}'
            else:
                target = '?'

            scope = p.get_type_display()

            def fmt(value):
                if value == FolderPermission.ALLOW:
                    return 'ALLOW'
                if value == FolderPermission.DENY:
                    return 'DENY'
                return '-'

            self.stdout.write(
                f'{p.id:>4} | {target:<30} | {scope:<10} | '
                f'{fmt(p.can_read):<6} | {fmt(p.can_edit):<6} | {fmt(p.can_add_children):<6}'
            )

    def _clear_permissions(self, folder):
        """Delete all permissions on a folder."""
        deleted, _ = FolderPermission.objects.filter(folder=folder).delete()
        self.stdout.write(self.style.SUCCESS(
            f'Deleted {deleted} permission(s) on "{folder.name}".'
        ))

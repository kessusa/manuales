@login_required
@require_POST
def move_file(request, file_id):
    """Move a file to a different folder (AJAX)."""
    target_folder_id = request.POST.get('target_folder_id') or None
    target_folder = Folder.objects.get(id=target_folder_id) if target_folder_id else None

    file_obj = get_object_or_404(File, id=file_id)
    if file_obj.folder and not _has_permission(request.user, file_obj.folder, 'can_edit'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})
    if target_folder and not _has_permission(request.user, target_folder, 'can_add_children'):
        return JsonResponse({'status': False, 'message': 'You cannot place files in the target folder.'})

    file_obj.folder = target_folder
    file_obj.save()

    target_label = target_folder.name if target_folder else 'root'
    return JsonResponse({
        'status': True,
        'message': f'File moved to "{target_label}".',
    })


@login_required
@require_POST
def move_folder(request, folder_id):
    """Move a folder under a different parent folder (AJAX)."""
    target_parent_id = request.POST.get('target_folder_id') or None
    folder = get_object_or_404(Folder, id=folder_id)

    if not _has_permission(request.user, folder, 'can_edit'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    if target_parent_id:
        target_parent = get_object_or_404(Folder, id=target_parent_id)
        if target_parent == folder or target_parent.is_descendant_of(folder):
            return JsonResponse({
                'status': False,
                'message': 'Cannot move a folder into itself or its children.',
            })
        if not _has_permission(request.user, target_parent, 'can_add_children'):
            return JsonResponse({'status': False, 'message': 'You cannot place folders in the target.'})
        folder.parent = target_parent
    else:
        folder.parent = None

    folder.save()

    target_label = folder.parent.name if folder.parent else 'root'
    return JsonResponse({
        'status': True,
        'message': f'Folder "{folder.name}" moved to "{target_label}".',
    })


# ---------------------------------------------------------------------------
# Permissions management UI
# ---------------------------------------------------------------------------

@login_required
def folder_permissions(request, folder_id):
    """List and manage permissions for a folder."""
    folder = get_object_or_404(Folder, id=folder_id)
    if not _has_permission(request.user, folder, 'can_edit') and not request.user.is_superuser:
        raise PermissionDenied

    perms = (
        FolderPermission.objects
        .filter(folder=folder)
        .select_related('user', 'group')
    )
    return render(request, 'tools/folder_permissions.html', {
        'folder': folder,
        'permissions': perms,
        'breadcrumbs': _build_breadcrumbs(folder),
        'all_users': User.objects.all().order_by('user_uid'),
        'all_groups': Group.objects.all().order_by('name'),
    })


@login_required
@require_POST
def add_folder_permission(request, folder_id):
    """Grant a permission on a folder (AJAX)."""
    folder = get_object_or_404(Folder, id=folder_id)
    if not _has_permission(request.user, folder, 'can_edit') and not request.user.is_superuser:
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    target_type = request.POST.get('target_type')
    can_read = request.POST.get('can_read') == 'allow'
    can_edit = request.POST.get('can_edit') == 'allow'
    can_add_children = request.POST.get('can_add_children') == 'allow'
    scope = request.POST.get('scope', 'this')

    scope_map = {
        'this': FolderPermission.THIS,
        'children': FolderPermission.CHILDREN,
        'all': FolderPermission.ALL,
    }

    perm = FolderPermission(
        folder=folder,
        type=scope_map.get(scope, FolderPermission.THIS),
        can_read=FolderPermission.ALLOW if can_read else FolderPermission.DENY,
        can_edit=FolderPermission.ALLOW if can_edit else FolderPermission.DENY,
        can_add_children=(
            FolderPermission.ALLOW if can_add_children else FolderPermission.DENY
        ),
    )

    if target_type == 'user':
        user_id = request.POST.get('user_id')
        if not user_id:
            return JsonResponse({'status': False, 'message': 'You must select a user.'})
        perm.user = get_object_or_404(User, id=user_id)
    elif target_type == 'group':
        group_id = request.POST.get('group_id')
        if not group_id:
            return JsonResponse({'status': False, 'message': 'You must select a group.'})
        perm.group = get_object_or_404(Group, id=group_id)
    elif target_type == 'everybody':
        perm.everybody = True
    else:
        return JsonResponse({'status': False, 'message': 'Invalid target type.'})

    perm.save()
    return JsonResponse({'status': True, 'message': 'Permission added successfully.'})


@login_required
@require_POST
def delete_folder_permission(request, perm_id):
    """Remove a folder permission (AJAX)."""
    perm = get_object_or_404(FolderPermission, id=perm_id)
    if (
        not _has_permission(request.user, perm.folder, 'can_edit')
        and not request.user.is_superuser
    ):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})
    perm.delete()
    return JsonResponse({'status': True, 'message': 'Permission removed.'})

"""
File manager views.

Location in project: rss/views.py

POST actions return JSON instead of redirecting + using Django messages,
so the frontend can show iziToast notifications directly without relying
on base.html's alert block.
"""
from django.contrib.auth.decorators import login_required
from django.contrib.auth.models import Group
from django.core.exceptions import PermissionDenied
from django.db.models import Q
from django.http import FileResponse, JsonResponse
from django.shortcuts import get_object_or_404, render
from django.views.decorators.http import require_POST

from filer.models import File, Folder, FolderPermission

from accounts.models import User


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _build_breadcrumbs(folder):
    """Return the chain of ancestor folders from root down to the given folder."""
    breadcrumbs = []
    node = folder
    while node is not None:
        breadcrumbs.insert(0, node)
        node = node.parent
    return breadcrumbs


def _folder_path(folder):
    """Return a human-readable path like 'Reports / 2026 / April'."""
    parts = []
    node = folder
    while node is not None:
        parts.insert(0, node.name)
        node = node.parent
    return ' / '.join(parts)


def _all_folders_for_picker():
    """Return all folders as dicts, used to populate move-to dropdowns."""
    return [
        {'id': f.id, 'path': _folder_path(f)}
        for f in Folder.objects.all().order_by('name')
    ]


def _ancestors_including(folder):
    """Yield the folder and all its ancestors, from leaf to root."""
    node = folder
    while node is not None:
        yield node
        node = node.parent


def _has_permission(user, folder, action):
    """
    Check whether `user` has a given `action` permission on `folder`.

    `action` is one of: 'can_read', 'can_edit', 'can_add_children'.
    """
    if user.is_superuser:
        return True

    if folder is None:
        return action == 'can_read'

    user_groups = user.groups.all()

    for distance, node in enumerate(_ancestors_including(folder)):
        relevant_scopes = [FolderPermission.ALL]
        if distance == 0:
            relevant_scopes.append(FolderPermission.THIS)
        else:
            relevant_scopes.append(FolderPermission.CHILDREN)

        perms = FolderPermission.objects.filter(
            folder=node, type__in=relevant_scopes
        ).filter(
            Q(user=user) | Q(group__in=user_groups) | Q(everybody=True)
        )

        if perms.filter(**{action: FolderPermission.DENY}).exists():
            return False
        if perms.filter(**{action: FolderPermission.ALLOW}).exists():
            return True

    return False


def _filter_visible_folders(user, queryset):
    """Return only folders from the queryset that the user can read."""
    if user.is_superuser:
        return queryset
    return [f for f in queryset if _has_permission(user, f, 'can_read')]


def _filter_visible_files(user, queryset):
    """Return only files whose folder the user can read."""
    if user.is_superuser:
        return queryset
    return [
        f for f in queryset
        if f.folder is None or _has_permission(user, f.folder, 'can_read')
    ]


# ---------------------------------------------------------------------------
# Browse (regular HTML view)
# ---------------------------------------------------------------------------

@login_required
def file_manager(request, folder_id=None):
    """Render the file manager view."""
    if folder_id:
        current_folder = get_object_or_404(Folder, id=folder_id)
        if not _has_permission(request.user, current_folder, 'can_read'):
            raise PermissionDenied('You do not have permission to view this folder.')
        subfolders = current_folder.children.all().order_by('name')
        files = current_folder.files.all().order_by('original_filename')
    else:
        current_folder = None
        subfolders = Folder.objects.filter(parent__isnull=True).order_by('name')
        files = File.objects.filter(folder__isnull=True).order_by('original_filename')

    visible_subfolders = _filter_visible_folders(request.user, subfolders)
    visible_files = _filter_visible_files(request.user, files)

    context = {
        'current_folder': current_folder,
        'subfolders': visible_subfolders,
        'files': visible_files,
        'breadcrumbs': _build_breadcrumbs(current_folder),
        'all_folders': _all_folders_for_picker(),
        'can_edit_current': (
            current_folder is None
            or _has_permission(request.user, current_folder, 'can_edit')
        ),
        'can_add_in_current': (
            current_folder is None
            or _has_permission(request.user, current_folder, 'can_add_children')
        ),
    }
    return render(request, 'tools/file_manager.html', context)


# ---------------------------------------------------------------------------
# Download (regular HTTP response, not JSON)
# ---------------------------------------------------------------------------

@login_required
def download_file(request, file_id):
    """Stream a file as an attachment so the browser triggers a download."""
    file_obj = get_object_or_404(File, id=file_id)
    if file_obj.folder and not _has_permission(request.user, file_obj.folder, 'can_read'):
        raise PermissionDenied
    return FileResponse(
        file_obj.file.open('rb'),
        as_attachment=True,
        filename=file_obj.original_filename,
    )


# ---------------------------------------------------------------------------
# AJAX actions: each returns JSON {status, message} so the frontend can
# show an iziToast notification directly.
# ---------------------------------------------------------------------------

@login_required
@require_POST
def upload_file(request):
    """Handle one or multiple file uploads via AJAX."""
    folder_id = request.POST.get('folder_id') or None
    target_folder = Folder.objects.get(id=folder_id) if folder_id else None

    if target_folder and not _has_permission(request.user, target_folder, 'can_add_children'):
        return JsonResponse({
            'status': False,
            'message': 'You do not have permission to upload to this folder.',
        })

    uploaded = request.FILES.getlist('files')
    if not uploaded:
        return JsonResponse({
            'status': False,
            'message': 'No files were selected.',
        })

    for uploaded_file in uploaded:
        File.objects.create(
            file=uploaded_file,
            folder=target_folder,
            original_filename=uploaded_file.name,
            owner=request.user,
        )

    return JsonResponse({
        'status': True,
        'message': f'{len(uploaded)} file(s) uploaded successfully.',
    })


@login_required
@require_POST
def delete_file(request, file_id):
    """Delete a single file (AJAX)."""
    file_obj = get_object_or_404(File, id=file_id)
    if file_obj.folder and not _has_permission(request.user, file_obj.folder, 'can_edit'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    file_name = file_obj.original_filename
    file_obj.delete()
    return JsonResponse({
        'status': True,
        'message': f'File "{file_name}" deleted successfully.',
    })


@login_required
@require_POST
def create_folder(request):
    """Create a new folder (AJAX)."""
    name = request.POST.get('name', '').strip()
    parent_id = request.POST.get('parent_id') or None

    if not name:
        return JsonResponse({'status': False, 'message': 'Folder name is required.'})

    parent = Folder.objects.get(id=parent_id) if parent_id else None
    if parent and not _has_permission(request.user, parent, 'can_add_children'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    Folder.objects.create(name=name, parent=parent, owner=request.user)
    return JsonResponse({
        'status': True,
        'message': f'Folder "{name}" created successfully.',
    })


@login_required
@require_POST
def delete_folder(request, folder_id):
    """Delete a folder and its contents (AJAX)."""
    folder = get_object_or_404(Folder, id=folder_id)
    if not _has_permission(request.user, folder, 'can_edit'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    folder_name = folder.name
    folder.delete()
    return JsonResponse({
        'status': True,
        'message': f'Folder "{folder_name}" deleted successfully.',
    })


@login_required
@require_POST
def rename_file(request, file_id):
    """Rename a file (AJAX)."""
    new_name = request.POST.get('new_name', '').strip()
    if not new_name:
        return JsonResponse({'status': False, 'message': 'New name is required.'})

    file_obj = get_object_or_404(File, id=file_id)
    if file_obj.folder and not _has_permission(request.user, file_obj.folder, 'can_edit'):
        return JsonResponse({'status': False, 'message': 'Permission denied.'})

    file_obj.name = new_name
    file_obj.original_filename = new_name
    file_obj.save()
    return JsonResponse({
        'status': True,
        'message': f'File renamed to "{new_name}".',
    })



# -*- coding: utf-8 -*-
"""
WAF LLM Analysis Engine.

Strategy:
  1. PRUNE       : rows whose AbuseIPDB score >= cleanup_threshold are removed
                   from the dataset BEFORE deduplication. They never reach the
                   LLM: they are classified as 'attack' and their analysis
                   columns explicitly state that no LLM was used.
  2. DEDUPLICATE : the remaining ("clean") rows are grouped into unique
                   signatures.
  3. MAP         : the LLM analyzes those signatures in batches, with
                   checkpointing and adaptive batch size.
  4. REDUCE      : verdicts are merged back, pruned rows are re-attached, and
                   the final Excel report keeps EVERY original row and column
                   plus the analysis columns.
"""

import os
import json
import re
import time
import hashlib

import pandas as pd
import requests
import urllib3

from bookmark.settings import MEDIA_ROOT, LLM_BASE_URL, LLM_MODEL, LLM_API_KEY

# Internal endpoint uses verify=False; silence the InsecureRequestWarning spam.
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BATCH_SIZE = 10                    # default signatures per LLM call
MAX_RETRIES = 3                    # retries per LLM batch
PAYLOAD_TRUNC = 300                # max chars kept from any payload/field
DEFAULT_CLEANUP_THRESHOLD = 10.0   # AbuseIPDB score at/above which a row is pruned
SCORE_COL = "Abuse Confidence Score"

# Message stored in the report for rows pruned by score (no LLM involved).
PRUNED_NOTE = "Automated verdict: AbuseIPDB score >= {thr}. LLM was NOT used for this row."

ANALYSIS_FIELDS = [
    "classification", "attack_confidence", "false_positive_confidence",
    "risk_level", "attack_type", "security_expert_analysis",
    "evidence_from_log", "why_it_may_be_false_positive", "production_impact",
    "recommended_action", "aviwaf_exception_type", "aviwaf_exception_scope",
    "aviwaf_exception_example", "safe_to_bypass", "code_fix_recommendation",
    "needs_manual_review",
]

SYSTEM_PROMPT = """ROLE
You are a senior cybersecurity analyst specialized in ModSecurity CRS,
AVI/NSX ALB WAF logs and production web application security.

OBJECTIVE
Analyze WAF event signatures. Distinguish real attacks from false positives.
Decide what should be blocked, monitored, or safely bypassed.


let finalText = "=== POLÍTICAS READY TO CLEAN UP (0 HITS) ===\n\n";

let i = 0;
for (const item of $input.all()) {
  // itemMatching rastrea automáticamente el origen de la fila usando el índice
  const match = $("Code in JavaScript").itemMatching(i);
  
  // Extraemos el ítem original de forma segura
  const itemOriginal = Array.isArray(match) ? match[0] : match;
  
  if (itemOriginal && itemOriginal.json) {
    finalText += itemOriginal.json.original_row + "\n";
  }
  
  i++; // Pasamos a la siguiente fila
}

return {
  json: {
    clean_report: finalText
  }
};

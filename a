    def get_package_installation_targets(self, session_id, policy_package_name):
        """
        Busca un Policy Package en los ADOMs y devuelve sus installation targets.
        Retorna una lista de diccionarios con el ADOM, dispositivo y VDOM.
        """
        # 1. Obtener la lista de todos los ADOMs
        adoms_res = self._request("get", "/dvmdb/adom", session_id=session_id)
        
        # Protección por si la llamada de ADOMs falla o la sesión expira
        if not adoms_res or "result" not in adoms_res:
            print("Error obteniendo la lista de ADOMs.")
            return []
            
        adoms = [adom["name"] for adom in adoms_res["result"][0].get("data", [])]
        targets_encontrados = []
        
        # 2. Iterar sobre los ADOMs
        for adom in adoms:
            endpoint = f"/pm/config/adom/{adom}/pkg/{policy_package_name}/installation target"
            
            res = self._request("get", endpoint, session_id=session_id)
            
            # Validamos si la petición fue exitosa (FortiManager devuelve code 0 si existe)
            status = res.get("result", [{}])[0].get("status", {})
            if status.get("code") != 0:
                continue  # El paquete no está en este ADOM, pasamos al siguiente
                
            data = res.get("result", [{}])[0].get("data", [])
            if not data:
                continue
                
            # 3. Extraer los equipos y VDOMs de forma segura
            for item in data:
                # Los targets pueden venir como objeto directo o dentro de 'scope member'
                scope_members = item.get("scope member", [item]) 
                
                for member in scope_members:
                    device_name = member.get("name", "")
                    # Si FortiManager no entrega la clave 'vdom', por defecto en FOS es 'root'
                    vdom_name = member.get("vdom", "root")
                    
                    if device_name:
                        targets_encontrados.append({
                            "adom": adom,
                            "device": device_name,
                            "vdom": vdom_name
                        })
            
            # Si ya encontramos targets, rompemos el bucle asumiendo que el nombre del paquete es único globalmente
            if targets_encontrados:
                break
                
        return targets_encontrados

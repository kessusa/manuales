from rss.models import Rule, Service

region, infra = 'amer', 'iv2'

# 1) En cada regla, quitar los enlaces duplicados por contenido (solo wrappers anónimos)
for rule in Rule.objects.filter(region=region, infra_type=infra):
    seen = set()
    for svc in list(rule.services.filter(name__isnull=True)):
        sig = frozenset(svc.content.values_list('id', flat=True))
        if sig in seen:
            rule.services.remove(svc)   # ya hay uno con ese contenido en esta regla
        else:
            seen.add(sig)

# 2) Borrar los wrappers anónimos que quedaron huérfanos (sin ninguna regla)
orphans = Service.objects.filter(name__isnull=True, rule__isnull=True)
print(orphans.count())   # míralo ANTES de borrar
orphans.delete()

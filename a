    def get_package_installation_targets(self, session_id, policy_package_name):
        """
        Busca un Policy Package en los ADOMs consultando el objeto directamente.
        Extrae y devuelve los installation targets ('scope member').
        """
        # 1. Obtener la lista de todos los ADOMs
        adoms_res = self._request("get", "/dvmdb/adom", session_id=session_id)
        
        if not adoms_res or "result" not in adoms_res:
            print("❌ Error obteniendo la lista de ADOMs.")
            return []
            
        # Extraemos los nombres de los ADOMs
        adoms = [adom["name"] for adom in adoms_res["result"][0].get("data", [])]
        
        # Opcional: Asegurarnos de que el ADOM 'root' esté en la lista por si acaso
        if "root" not in adoms:
            adoms.append("root")

        targets_encontrados = []
        
        # 2. Iterar sobre los ADOMs buscando el paquete
        for adom in adoms:
            # 🚨 EL ENDPOINT CORRECTO: Pedimos el objeto del paquete directamente
            endpoint = f"/pm/pkg/adom/{adom}/{policy_package_name}"
            
            res = self._request("get", endpoint, session_id=session_id)
            
            # Validamos si la petición fue exitosa (code 0 = existe, code -3 = no existe)
            status = res.get("result", [{}])[0].get("status", {})
            if status.get("code") != 0:
                continue  # El paquete no está en este ADOM, probamos el siguiente
                
            # Si llegamos aquí, ¡encontramos el paquete!
            data = res.get("result", [{}])[0].get("data", {})
            
            # FortiManager a veces devuelve un dict directo o una lista con un dict
            if isinstance(data, list) and len(data) > 0:
                pkg_data = data[0]
            elif isinstance(data, dict):
                pkg_data = data
            else:
                continue

            # 3. Extraer los equipos de la propiedad 'scope member'
            scope_members = pkg_data.get("scope member", [])
            
            if not scope_members:
                print(f"⚠️ El paquete '{policy_package_name}' se encontró en el ADOM '{adom}', pero NO tiene installation targets asignados.")
                continue

            for member in scope_members:
                device_name = member.get("name", "")
                vdom_name = member.get("vdom", "root")
                
                if device_name:
                    targets_encontrados.append({
                        "adom": adom,
                        "device": device_name,
                        "vdom": vdom_name
                    })
            
            # Como ya encontramos el paquete y sus targets, no hace falta seguir buscando en otros ADOMs
            if targets_encontrados:
                break
                
        return targets_encontrados

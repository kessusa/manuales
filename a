/* 1) Posición horizontal — nth-of-type (NO nth-child) para que el
      <input type="hidden"> del <tr> no descuadre el conteo */
.table-scroll .sticky-col:nth-of-type(1) {
  position: sticky;
  left: 0;
  width: 60px;
  min-width: 60px;
  max-width: 60px;
  background: #fff;
  box-sizing: border-box;
}
.table-scroll .sticky-col:nth-of-type(2) {
  position: sticky;
  left: 60px;                 /* = ancho de la columna 1 */
  min-width: 150px;
  background: #fff;
  box-sizing: border-box;
}

/* 2) Cabecera fija (vertical), por encima del cuerpo */
.table-scroll thead th {
  position: sticky;
  top: 0;
  z-index: 3;
  background: #fff;
}

/* 3) Columnas fijas del cuerpo por encima de lo que scrollea
      (esto evita que los badges/"show more" se transparenten) */
.table-scroll tbody .sticky-col {
  z-index: 2;
}

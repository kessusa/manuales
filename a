# FortiManager API connector.
# FortiManager exposes a JSON-RPC API : every call is a POST request to the
# same endpoint (the base url already ends with /jsonrpc). The payload always
# contains :
#   - 'method'  : 'get' to read data, 'exec' to run an action
#   - 'params'  : a list with one dict holding 'url' (the resource path)
#                 and optionally 'data' (the arguments)
#   - 'session' : the session token returned by login, None only for login
import time

import requests
import urllib3

from bookmark.settings import (
    FORTIMANAGER_BASE_URL,
    get_fortimanager_auth_credentials,
    BNP_HEADERS,
)

# We connect with 'verify': False (internal self-signed certificate),
# this disables the InsecureRequestWarning printed on every request
urllib3.disable_warnings()


class FortiManagerAPI:
    def __init__(self):

        # FORTIMANAGER_BASE_URL already includes /jsonrpc, so every request
        # posts directly to self.base_url
        self.base_url = FORTIMANAGER_BASE_URL

        # Tuple (username, password) coming from settings / CyberArk
        self.auth_credentials = get_fortimanager_auth_credentials()

        # Headers
        self.headers = BNP_HEADERS

        # Common arguments for every requests.post call :
        # no proxy, project headers and no TLS verification
        self.connection_args = {
            'proxies': {'https': None},
            'headers': self.headers,
            'verify': False
        }

    # # Login : opens a session and returns the session token (sid),
    # # required by every other method
    def login(self):
        payload = {
            'id': 1,
            'method': 'exec',
            'params': [
                {
                    'url': '/sys/login/user',
                    'data': {
                        'user': self.auth_credentials[0],
                        'passwd': self.auth_credentials[1]
                    }
                }
            ],
            # login is the only call made without a session token
            'session': None
        }
        self.connection_args['json'] = payload

        response = requests.post(self.base_url, **self.connection_args).json()

        # the session token is returned at the top level of the response
        return response.get('session', None)

    # # Logout : closes the session so it does not stay open on the server
    def logout(self, sid):
        payload = {
            'id': 1,
            'method': 'exec',
            'params': [
                {
                    'url': '/sys/logout'
                }
            ],
            'session': sid
        }
        self.connection_args['json'] = payload

        requests.post(self.base_url, **self.connection_args)

    # # Lock ADOM : our FortiManager runs in workspace mode, so the ADOM
    # # workspace must be locked before any securityconsole operation
    def lock_adom(self, sid, adom):
        payload = {
            'id': 1,
            'method': 'exec',
            'params': [
                {
                    'url': f'/dvmdb/adom/{adom}/workspace/lock'
                }
            ],
            'session': sid
        }
        self.connection_args['json'] = payload

        requests.post(self.base_url, **self.connection_args)

    # # Unlock ADOM : releases the workspace lock so other users / the GUI
    # # can work on the ADOM again
    def unlock_adom(self, sid, adom):
        payload = {
            'id': 1,
            'method': 'exec',
            'params': [
                {
                    'url': f'/dvmdb/adom/{adom}/workspace/unlock'
                }
            ],
            'session': sid
        }
        self.connection_args['json'] = payload

        requests.post(self.base_url, **self.connection_args)

    # # Wait for task : securityconsole operations are asynchronous, they
    # # return a task id. This polls the task every 2 seconds until it
    # # reaches 100% or the timeout is exceeded, and returns the task data
    def wait_for_task(self, sid, task_id, timeout=120):
        task = {}
        elapsed = 0

        while elapsed < timeout:
            payload = {
                'id': 1,
                'method': 'get',
                'params': [
                    {
                        'url': f'/task/task/{task_id}'
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            response = requests.post(self.base_url, **self.connection_args).json()

            task = response.get('result', [{}])[0].get('data', {})

            if task.get('percent') == 100:
                break

            time.sleep(2)
            elapsed += 2

        return task

    # # Get data : returns the firewall rules of a policy package with
    # # their IPS profiles (main requirement of the Jira ticket)
    def get_data(self, sid, adom, package):
        result = []

        payload = {
            'id': 1,
            'method': 'get',
            'params': [
                {
                    'url': f'/pm/config/adom/{adom}/pkg/{package}/firewall/policy',
                    # only retrieve the fields we use, to keep the
                    # response small
                    'fields': [
                        'policyid', 'name', 'srcaddr', 'dstaddr', 'service',
                        'action', 'status', 'utm-status', 'ips-sensor',
                        'comments'
                    ]
                }
            ],
            'session': sid
        }
        self.connection_args['json'] = payload

        response = requests.post(self.base_url, **self.connection_args).json()

        # code 0 means the request succeeded
        status = response.get('result', [{}])[0].get('status', {})

        if status.get('code') == 0:
            for item in response['result'][0].get('data', []):
                if item.get('policyid'):

                    # 'ips-sensor' comes as a list with a single profile name
                    ips_profile = item['ips-sensor'][0] if item.get('ips-sensor', None) else None

                    result_dict = {
                        'rule_id': item.get('policyid'),
                        'rule_name': item.get('name', None),
                        'source': item.get('srcaddr', None),
                        'destination': item.get('dstaddr', None),
                        'service': item.get('service', None),
                        'action': item.get('action', None),
                        'status': item.get('status', None),
                        'utm_status': item.get('utm-status', None),
                        'ips_profile': ips_profile,
                        'comments': item.get('comments', None)
                    }
                    result.append(result_dict)

        return result

    # # Find package : searches a policy package by name across all ADOMs
    # # and returns its adom and installation targets. Packages without
    # # installation targets are skipped because it usually means the
    # # package was moved to another ADOM, so we keep searching
    def find_policy_package(self, sid, package_name):
        result = None

        # list every ADOM of the FortiManager
        payload = {
            'id': 1,
            'method': 'get',
            'params': [
                {
                    'url': '/dvmdb/adom',
                    'fields': ['name']
                }
            ],
            'session': sid
        }
        self.connection_args['json'] = payload

        response = requests.post(self.base_url, **self.connection_args).json()

        adoms = response.get('result', [{}])[0].get('data', [])

        for adom_item in adoms:
            adom = adom_item.get('name', None)

            if adom:
                # list the policy packages of the ADOM (tree structure :
                # packages can be nested inside folders)
                payload = {
                    'id': 1,
                    'method': 'get',
                    'params': [
                        {
                            'url': f'/pm/pkg/adom/{adom}'
                        }
                    ],
                    'session': sid
                }
                self.connection_args['json'] = payload

                response = requests.post(self.base_url, **self.connection_args).json()

                items = response.get('result', [{}])[0].get('data', [])

                package = self.search_package_in_tree(items, package_name)

                if package:
                    # 'scope member' holds the installation targets of the
                    # package : the devices (and their vdom) it installs to
                    installation_targets = []

                    for target in package.get('scope member', []):
                        result_dict = {
                            'device': target.get('name', None),
                            'vdom': target.get('vdom', None)
                        }
                        installation_targets.append(result_dict)

                    # skip packages without installation targets and keep
                    # searching in the remaining ADOMs
                    if installation_targets:
                        result = {
                            'adom': adom,
                            'package': package.get('name', None),
                            'installation_targets': installation_targets
                        }
                        break

        return result

    # # Search package in tree : recursive helper for find_policy_package.
    # # Packages can be nested inside folders, folders hold their children
    # # in 'subobj'
    def search_package_in_tree(self, nodes, package_name):
        found = None

        for item in nodes or []:

            # a package is identified by type 'pkg'
            if item.get('type') == 'pkg' and item.get('name') == package_name:
                found = item
                break

            # go down into folders
            if item.get('subobj', None) or item.get('type') == 'folder':
                found = self.search_package_in_tree(item.get('subobj', []), package_name)

                if found:
                    break

        return found

    # # Preview : generates the install preview of a policy package and
    # # returns the pending changes (CLI diff) per installation target.
    # # This is a 4 step process defined by Fortinet :
    # #   1. install the package with the 'preview' flag (dry-run, nothing
    # #      is installed) to generate the preview cache on each device
    # #   2. run install/preview per device to build the preview report
    # #   3. read the report with preview/result
    # #   4. cancel the install process to clear the preview session,
    # #      otherwise it stays open and blocks the next previews
    def preview_policy_package(self, sid, adom, package, timeout=120):
        result = []

        # the ADOM workspace must be locked during the whole process
        self.lock_adom(sid, adom)

        try:
            # get the installation targets ('scope member') of the package,
            # they are passed as 'scope' to the securityconsole calls
            payload = {
                'id': 1,
                'method': 'get',
                'params': [
                    {
                        'url': f'/pm/pkg/adom/{adom}/{package}'
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            response = requests.post(self.base_url, **self.connection_args).json()

            scope = response.get('result', [{}])[0].get('data', {}).get('scope member', [])

            # step 1 : install the package in preview mode (dry-run) to
            # generate the preview cache on the devices
            payload = {
                'id': 1,
                'method': 'exec',
                'params': [
                    {
                        'url': '/securityconsole/install/package',
                        'data': {
                            'adom': adom,
                            'pkg': package,
                            'scope': scope,
                            'flags': ['preview']
                        }
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            response = requests.post(self.base_url, **self.connection_args).json()

            task_id = response.get('result', [{}])[0].get('data', {}).get('task', None)

            if task_id:
                # the install runs asynchronously, wait for it to finish
                self.wait_for_task(sid, task_id, timeout)

                for target in scope:
                    device = target.get('name', None)
                    vdom = target.get('vdom', None)

                    if device:
                        # step 2 : build the preview report of the device.
                        # 'scope' is the attribute expected by recent
                        # FortiManager versions (7.4.4+), 'flags': ['none']
                        # returns the report in CLI format
                        payload = {
                            'id': 1,
                            'method': 'exec',
                            'params': [
                                {
                                    'url': '/securityconsole/install/preview',
                                    'data': {
                                        'adom': adom,
                                        'flags': ['none'],
                                        'scope': [{'name': device, 'vdom': vdom}]
                                    }
                                }
                            ],
                            'session': sid
                        }
                        self.connection_args['json'] = payload

                        response = requests.post(self.base_url, **self.connection_args).json()

                        preview_task_id = response.get('result', [{}])[0].get('data', {}).get('task', None)

                        if preview_task_id:
                            self.wait_for_task(sid, preview_task_id, timeout)

                            # step 3 : read the preview report, the CLI diff
                            # is returned in the 'message' field
                            payload = {
                                'id': 1,
                                'method': 'exec',
                                'params': [
                                    {
                                        'url': '/securityconsole/preview/result',
                                        'data': {
                                            'adom': adom,
                                            'scope': [{'name': device, 'vdom': vdom}]
                                        }
                                    }
                                ],
                                'session': sid
                            }
                            self.connection_args['json'] = payload

                            response = requests.post(self.base_url, **self.connection_args).json()

                            message = response.get('result', [{}])[0].get('data', {}).get('message', None)

                            result_dict = {
                                'device': device,
                                'vdom': vdom,
                                'preview': message
                            }
                            result.append(result_dict)

        finally:
            # step 4 : always cancel the install process and release the
            # workspace, even if something failed above, so we never leave
            # a hanging install session or a locked ADOM behind
            payload = {
                'id': 1,
                'method': 'exec',
                'params': [
                    {
                        'url': '/securityconsole/package/cancel/install',
                        'data': {
                            'adom': adom
                        }
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            requests.post(self.base_url, **self.connection_args)

            self.unlock_adom(sid, adom)

        return result

    # # Install : installs a policy package on its installation targets.
    # # WARNING : unlike the preview, this pushes the configuration to the
    # # real devices. Returns the final task status per device so the caller
    # # can verify the installation result
    def install_policy_package(self, sid, adom, package, timeout=300):
        result = {}

        # the ADOM workspace must be locked during the installation
        self.lock_adom(sid, adom)

        try:
            # get the installation targets ('scope member') of the package
            payload = {
                'id': 1,
                'method': 'get',
                'params': [
                    {
                        'url': f'/pm/pkg/adom/{adom}/{package}'
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            response = requests.post(self.base_url, **self.connection_args).json()

            scope = response.get('result', [{}])[0].get('data', {}).get('scope member', [])

            # install the package : same call as the preview but without the
            # 'preview' flag. 'generate_rev' creates an ADOM revision before
            # installing, so the change can be rolled back if needed
            payload = {
                'id': 1,
                'method': 'exec',
                'params': [
                    {
                        'url': '/securityconsole/install/package',
                        'data': {
                            'adom': adom,
                            'pkg': package,
                            'scope': scope,
                            'flags': ['generate_rev']
                        }
                    }
                ],
                'session': sid
            }
            self.connection_args['json'] = payload

            response = requests.post(self.base_url, **self.connection_args).json()

            task_id = response.get('result', [{}])[0].get('data', {}).get('task', None)

            if task_id:
                # installation can take a while on real devices, wait for it
                task = self.wait_for_task(sid, task_id, timeout)

                # one line per device with its own state and detail, so the
                # caller can check which devices installed correctly
                devices = []

                for line in task.get('line', []):
                    result_dict = {
                        'device': line.get('name', None),
                        'state': line.get('state', None),
                        'detail': line.get('detail', None),
                        'percent': line.get('percent', None)
                    }
                    devices.append(result_dict)

                result = {
                    'task_id': task_id,
                    'percent': task.get('percent', None),
                    'state': task.get('state', None),
                    'devices': devices
                }

        finally:
            # always release the workspace, even if the installation failed
            self.unlock_adom(sid, adom)

        return result

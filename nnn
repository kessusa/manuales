const items = $input.all();
const output = [];

for (const item of items) {
  const raw =
    item.json.output ||
    item.json.text ||
    item.json.response ||
    item.json.message ||
    item.json.content ||
    item.json.result ||
    "";

  let parsed;

  try {
    parsed = typeof raw === "string" ? JSON.parse(raw) : raw;
  } catch (error) {
    throw new Error("La IA no devolvió JSON válido: " + raw);
  }

  const rows = Array.isArray(parsed)
    ? parsed
    : parsed.results || parsed.rows || [];

  for (const row of rows) {
    output.push({
      json: row
    });
  }
}

return output;

"""
Snippet to add to rss/views.py to compute folder statistics.

Place the helper somewhere near _has_permission, then call it from the
file_manager view right after you have the list of subfolders to display.
"""
from django.db.models import Sum
from filer.models import File


def _annotate_folder_stats(folders):
    """
    Add three attributes to each folder in the iterable:
        - total_size:       recursive sum of file sizes (bytes)
        - total_files:      recursive count of files
        - total_subfolders: recursive count of subfolders (excluding self)

    Uses MPTT (django-mptt) get_descendants() which is what django-filer
    inherits from, so this is one quick query per folder.
    """
    for folder in folders:
        descendant_ids = list(
            folder.get_descendants(include_self=True).values_list('id', flat=True)
        )

        size_agg = File.objects.filter(folder_id__in=descendant_ids).aggregate(
            total=Sum('_file_size')
        )
        folder.total_size = size_agg['total'] or 0

        folder.total_files = File.objects.filter(folder_id__in=descendant_ids).count()
        folder.total_subfolders = folder.get_descendants().count()



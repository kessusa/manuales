# -*- coding: utf-8 -*-
"""
Núcleo del agente de incidencias — v2 con function calling nativo.
El gateway (vLLM) devuelve tool_calls estructuradas: no hay parseo de texto.
Añadir herramientas nuevas = registrarlas con @registry.tool(...); el schema
OpenAI se genera solo.
"""
import json
import requests


# ============================================================
# 1. TOOL REGISTRY  →  genera el schema "tools" de OpenAI
# ============================================================
class ToolRegistry:
    def __init__(self):
        self._tools = {}

    def tool(self, name, description, params, required=None):
        """params: dict {arg: descripción} (todos string por defecto)
        o {arg: {"type": "integer", "description": "..."}} para otros tipos."""
        def wrapper(fn):
            props = {}
            for k, v in params.items():
                props[k] = v if isinstance(v, dict) else {"type": "string", "description": v}
            self._tools[name] = {
                "fn": fn,
                "schema": {
                    "type": "function",
                    "function": {
                        "name": name,
                        "description": description,
                        "parameters": {
                            "type": "object",
                            "properties": props,
                            "required": required if required is not None else list(params),
                        },
                    },
                },
            }
            return fn
        return wrapper

    def schemas(self):
        return [t["schema"] for t in self._tools.values()]

    def execute(self, name, args):
        if name not in self._tools:
            return {"error": f"Tool '{name}' no existe. Disponibles: {list(self._tools)}"}
        try:
            return self._tools[name]["fn"](**args)
        except TypeError as e:
            return {"error": f"Argumentos inválidos para {name}: {e}"}
        except Exception as e:
            return {"error": str(e)}


# ============================================================
# 2. CLIENTE LLM (devuelve el message completo, con tool_calls)
# ============================================================
class LLMClient:
    def __init__(self, base_url, model, api_key, verify=False):
        self.base_url = base_url
        self.model = model
        self.api_key = api_key
        self.verify = verify

    def chat(self, messages, tools=None, temperature=0):
        headers = {"Authorization": f"Bearer {self.api_key}",
                   "Content-Type": "application/json"}
        data = {"model": self.model, "messages": messages, "temperature": temperature}
        if tools:
            data["tools"] = tools
            data["tool_choice"] = "auto"
        r = requests.post(self.base_url, headers=headers, json=data,
                          verify=self.verify, timeout=120)
        r.raise_for_status()
        return r.json()["choices"][0]["message"]


# ============================================================
# 3. AGENTE
# ============================================================
SYSTEM_PROMPT = """You are a Tier 3 Network Security Operations Center (SOC) Engineer.
Your goal is to investigate ServiceNow incidents and determine whether a
connectivity issue is caused by a missing firewall rule.

WORKFLOW:
1. Call check_flow with src_ip, dst_ip and service (format 'protocol-port',
   e.g. 'tcp-3389'). It returns the matching firewall rule directly.
2. Conclude from its result:
   - action 'accept': the firewall is NOT the issue; cite tag and rule
     position; suggest checking the endpoint/application.
   - action 'drop' or 'no_match': the firewall is blocking the traffic;
     provide the tag name for the rule request.
3. Only use get_topology_for_ip or list_rules_in_tag if check_flow errors
   or you need extra context (e.g. IP not found in topology).

RULES:
- Use the tools to confirm findings. Do not guess.
- Do not repeat a tool call you already made; use its result.
- When the investigation is complete, answer in plain text (no tool call) with:
  ROOT CAUSE, TECHNICAL DETAILS, NEXT STEPS."""


class IncidentAgent:
    def __init__(self, llm: LLMClient, registry: ToolRegistry, max_iters=8):
        self.llm = llm
        self.registry = registry
        self.max_iters = max_iters

    def investigate(self, context: str):
        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": context},
        ]
        seen_calls = set()

        for i in range(self.max_iters):
            print(f"\n--- Iteración {i + 1} ---")
            msg = self.llm.chat(messages, tools=self.registry.schemas())
            tool_calls = msg.get("tool_calls") or []
            content = msg.get("content") or ""

            # Sin tool_calls y con texto → respuesta final
            if not tool_calls:
                print(f"[LLM] {content}")
                if content.strip():
                    return {"status": "resolved", "analysis": content.strip(),
                            "iterations": i + 1}
                messages.append({"role": "user", "content":
                    "Your last message was empty. Either call a tool or give "
                    "your final analysis in plain text."})
                continue

            # Ecoar el mensaje del asistente tal cual (requerido por la API)
            messages.append({
                "role": "assistant",
                "content": content,
                "tool_calls": [
                    {"id": tc["id"], "type": "function",
                     "function": {"name": tc["function"]["name"],
                                  "arguments": tc["function"]["arguments"]}}
                    for tc in tool_calls
                ],
            })

            for tc in tool_calls:
                name = tc["function"]["name"]
                try:
                    args = json.loads(tc["function"]["arguments"] or "{}")
                except json.JSONDecodeError:
                    args, observation = {}, {"error": "Malformed arguments JSON"}
                else:
                    key = f"{name}:{json.dumps(args, sort_keys=True)}"
                    if key in seen_calls:
                        observation = {"warning":
                            "You already called this with the same arguments. "
                            "Use the previous result or give your final answer."}
                    else:
                        seen_calls.add(key)
                        print(f"[Agent] Ejecutando: {name}({args})")
                        observation = self.registry.execute(name, args)
                print(f"[Observation] {observation}")
                messages.append({
                    "role": "tool",
                    "tool_call_id": tc["id"],
                    "content": json.dumps(observation, ensure_ascii=False),
                })

        return {"status": "error", "message": "Max iterations reached",
                "trace": messages}

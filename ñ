IPS_APP_SCOPE_PATTERNS = (
    'DMZI_APPL', 'DMZI_PRES_BASTION', 'CORE_MKT-ETS',
    'CORE_WIN', 'CAMPUS', 'HVD', 'PETAL',
    'DMZI_PRES_WIFI', 'EMEA_FR_DEV_CORE',
)
DMZE_EXCLUDED = ('DMZE_MKT', 'DMZE_COLO')

def requires_ips_app_control(tag_name, technology):
    if not technology or technology.upper() != 'FORTINET':
        return False
    name = (tag_name or '').upper()
    if any(p in name for p in IPS_APP_SCOPE_PATTERNS):
        return True
    if 'DMZE' in name and not any(e in name for e in DMZE_EXCLUDED):
        return True
    return False


@property
def in_ips_scope(self):
    from utils.util_tools import requires_ips_app_control
    return requires_ips_app_control(self.tag_name, self.technology)

Keep free-text fields under 25 words."""

REDUCE_PROMPT = "Produce ONLY a valid JSON summary of these WAF statistics and verdicts."

# Recommended batch size per model (bigger context -> bigger batch).
MODEL_BATCH = {
    "llama3.3-70b": 10,
    "gpt-oss-120b": 8,
    "gemma-4-31b": 4,
}


# ---------------------------------------------------------------------------
# LLM Core Utilities (Stream & JSON)
# ---------------------------------------------------------------------------

def _consume_stream(headers, data):
    """Accumulate an SSE streaming response (prevents 504 gateway timeouts)."""
    chunks = []
    with requests.post(LLM_BASE_URL, headers=headers, json=data, verify=False,
                       stream=True, timeout=(10, 600)) as r:
        r.raise_for_status()
        for raw in r.iter_lines():
            if not raw:
                continue
            line = raw.decode("utf-8", errors="ignore")
            if not line.startswith("data:"):
                continue
            payload = line[5:].strip()
            if payload == "[DONE]":
                break
            try:
                delta = (json.loads(payload)["choices"][0]
                         .get("delta", {}).get("content") or "")
                chunks.append(delta)
            except (ValueError, KeyError, IndexError):
                continue
    return "".join(chunks)


def _llm_json(system, user, retries=MAX_RETRIES, model=None, stream=True):
    """Call the LLM and return parsed JSON. Retries with error feedback
    appended to the prompt when the model returns invalid JSON."""
    model = model or LLM_MODEL
    headers = {"Authorization": f"Bearer {LLM_API_KEY}",
               "Content-Type": "application/json"}
    last_err = None

    for attempt in range(retries):
        data = {
            "model": model, "stream": stream, "temperature": 0,
            "messages": [{"role": "system", "content": system},
                         {"role": "user", "content": user}],
        }
        try:
            if stream:
                content = _consume_stream(headers, data)
            else:
                r = requests.post(LLM_BASE_URL, headers=headers, json=data,
                                  verify=False, timeout=180)
                r.raise_for_status()
                content = r.json()["choices"][0]["message"]["content"]

            # Strip markdown fences some models insist on adding.
            clean = content.replace("```json", "").replace("```", "").strip()
            return json.loads(clean)
        except Exception as e:
            last_err = str(e)
            user += (f"\n\nYour previous answer was invalid ({last_err}). "
                     f"Return ONLY the JSON array.")
            time.sleep(2 * (attempt + 1))

    raise RuntimeError(f"LLM failed after {retries} attempts: {last_err}")


# ---------------------------------------------------------------------------
# Data Processing & Deduplication
# ---------------------------------------------------------------------------

def _normalize_payload(text):
    """Collapse variable values (numbers, hashes, query strings) so that
    equivalent payloads produce the same signature hash."""
    t = str(text)[:PAYLOAD_TRUNC]
    t = t.split("?")[0] if t.startswith("/") else t   # drop query string from URLs
    t = re.sub(r"\d+", "<N>", t)                      # any number -> <N>
    t = re.sub(r"[0-9a-fA-F]{8,}", "<HEX>", t)        # long hex/hash -> <HEX>
    if "," in t:
        tokens = [x.strip() for x in t.split(",")]
        t = ",".join(sorted(set(tokens))[:3])         # stable order, keep 3 tokens
    return t.lower()


def build_signatures(df, sig_columns, extra_context_columns=None, count_column=None):
    """Group rows into unique signatures.

    Adds a 'signature_id' column to the DataFrame and returns a dict
    {signature_id: entry} with the representative payloads and up to
    3 sample values for each context column."""
    extra_context_columns = extra_context_columns or []

    def sig_of(row):
        parts = [_normalize_payload(row.get(c, "")) for c in sig_columns]
        return hashlib.md5("|".join(parts).encode()).hexdigest()[:12]

    df = df.copy()
    df["signature_id"] = df.apply(sig_of, axis=1)

    signatures = {}
    for sig_id, grp in df.groupby("signature_id"):
        first = grp.iloc[0]
        # Weighted occurrences if a Count column exists, otherwise row count.
        occurrences = (int(grp[count_column].fillna(1).sum())
                       if count_column and count_column in grp
                       else int(len(grp)))

        entry = {"signature_id": sig_id, "occurrences": occurrences}
        for c in sig_columns:
            entry[c] = str(first.get(c, ""))[:PAYLOAD_TRUNC]
        for c in extra_context_columns:
            # dropna() BEFORE astype(str), otherwise NaN becomes the string "nan".
            entry[c + "_sample"] = grp[c].dropna().astype(str).unique()[:3].tolist()
        signatures[sig_id] = entry

    return df, signatures


def _pruned_verdict(sig_id, threshold):
    """Verdict assigned to signatures skipped by the score-based pruning.
    Keeps the exact same schema as an LLM verdict so the merge is uniform."""
    v = {k: "" for k in ANALYSIS_FIELDS}
    v.update({
        "signature_id": sig_id,
        "classification": "attack",
        "attack_confidence": 100,
        "false_positive_confidence": 0,
        "risk_level": "high",
        "attack_type": "unknown",
        "recommended_action": "block",
        "security_expert_analysis": PRUNED_NOTE.format(thr=threshold),
        "safe_to_bypass": False,
        "needs_manual_review": False,
    })
    return v


# ---------------------------------------------------------------------------
# LLM Execution Logic
# ---------------------------------------------------------------------------

def analyze_signatures(signatures, checkpoint_path, model=None, batch_size=None):
    """Run the LLM over the signatures in batches.

    - Resumes from a JSON checkpoint if the previous run was interrupted.
    - Halves the batch size when a batch fails (adaptive sizing).
    - Any signature that never gets a valid answer is flagged as
      'unknown' + needs_manual_review instead of being retried forever."""
    model = model or LLM_MODEL
    size = batch_size or MODEL_BATCH.get(model, BATCH_SIZE)

    done = {}
    if os.path.exists(checkpoint_path):
        with open(checkpoint_path) as f:
            done = json.load(f)

    pending = [s for sid, s in signatures.items() if sid not in done]
    i = 0

    while i < len(pending):
        batch = pending[i:i + size]
        user_prompt = f"SIGNATURES\n{json.dumps(batch, ensure_ascii=False, indent=1)}"

        try:
            results = _llm_json(SYSTEM_PROMPT, user_prompt, model=model)
            valid = 0
            for item in (results if isinstance(results, list) else []):
                sid = item.get("signature_id")
                # Accept only complete, well-formed verdicts.
                if sid in signatures and all(k in item for k in ANALYSIS_FIELDS):
                    done[sid] = item
                    valid += 1

            i += len(batch)
            with open(checkpoint_path, "w") as f:
                json.dump(done, f)
            print(f"Progress {min(i, len(pending))}/{len(pending)} "
                  f"(Batch: {len(batch)}, Valid: {valid})")

        except RuntimeError:
            if size > 1:
                size = max(1, size // 2)
                print(f"Batch failed -> New size: {size}")
            else:
                i += 1  # single signature keeps failing -> skip it

    # Backfill: anything without a valid verdict goes to manual review.
    for sid in signatures:
        if sid not in done:
            done[sid] = {k: "" for k in ANALYSIS_FIELDS}
            done[sid].update({"signature_id": sid,
                              "classification": "unknown",
                              "needs_manual_review": True})
    return done


# ---------------------------------------------------------------------------
# Aggregation (REDUCE)
# ---------------------------------------------------------------------------

def dataset_analysis(df, verdicts, ip_col="ip", count_column=None, model=None):
    """Merge the verdicts back into EVERY original row (left join on
    signature_id) and compute weighted summary statistics."""
    v = pd.DataFrame(verdicts.values())
    merged = df.merge(v, on="signature_id", how="left")

    # Event weight: use the Count column when present, else 1 per row.
    w = (merged[count_column].fillna(1)
         if count_column and count_column in merged
         else pd.Series(1, index=merged.index))
    merged["_w"] = w

    stats = {
        "total_events": int(w.sum()),
        "total_rows": int(len(df)),
        "unique_signatures": int(len(verdicts)),
        "by_classification": merged.groupby("classification")["_w"].sum().astype(int).to_dict(),
        "by_risk_level": merged.groupby("risk_level")["_w"].sum().astype(int).to_dict(),
        "top_offenders": (merged[merged["classification"] == "attack"]
                          .groupby(ip_col)["_w"].sum().astype(int)
                          .nlargest(10).to_dict()
                          if ip_col in merged else {}),
    }

    # REDUCE step: short LLM executive summary (non-fatal if it fails).
    interesting = [x for x in verdicts.values()
                   if x.get("classification") in ("attack", "false_positive")]
    user = f"STATS\n{json.dumps(stats)}\n\nVERDICTS\n{json.dumps(interesting[:100])}"
    try:
        summary = _llm_json(REDUCE_PROMPT, user, model=model)
        if not isinstance(summary, dict):
            summary = {"summary": summary}
    except RuntimeError as e:
        summary = {"summary": f"Reduce step failed: {e}"}
    summary.update(stats)

    return merged.drop(columns=["_w"]), summary


# ---------------------------------------------------------------------------
# Main Orchestrator
# ---------------------------------------------------------------------------

def waf_llm_report(input_file, sig_columns=None, extra_context_columns=None,
                   count_column="Count", model=None, batch_size=None,
                   use_llm=True, cleanup_threshold=DEFAULT_CLEANUP_THRESHOLD):
    """Main orchestrator.

    :param cleanup_threshold: IPs with AbuseIPDB score >= this value are
        treated as known attackers. Signatures made up ONLY of such IPs are
        classified as 'attack' WITHOUT calling the LLM. Their rows keep all
        the original data, and the analysis columns explicitly say that no
        LLM was used for them.
    :returns: (output_file_path, summary_dict)
    """
    # 1. Load and clean headers ("Header: description" -> "Header").
    df = pd.read_excel(input_file)
    df.columns = [str(c).split(":")[0].strip() for c in df.columns]

    # Identify the IP column and normalize its name to 'ip'.
    ip_col = next((n for n in ("ip", "original_client_ip", "client_ip")
                   if n in df.columns), df.columns[0])
    df.rename(columns={ip_col: "ip"}, inplace=True)
    ip_col = "ip"

    sig_columns = sig_columns or [
        "waf.rule.id", "url.path",
        "avi.waf_log.rule_logs.matches.match_element",
    ]
    extra_context_columns = extra_context_columns or [ip_col, "waf.rule.match_value"]

    # 2. Deduplicate rows into unique signatures.
    df, signatures = build_signatures(df, sig_columns, extra_context_columns, count_column)
    print(f"{len(df)} rows -> {len(signatures)} unique signatures")

    checkpoint = f"{MEDIA_ROOT}/avi_iwaf/waf_llm_checkpoint.json"

    if use_llm:
        # 3. Intelligence pruning: everything above the score threshold is
        #    removed from the LLM input and auto-classified as 'attack'.
        verdicts = {}
        to_analyze = dict(signatures)

        if SCORE_COL in df.columns:
            known_bad = set(df.loc[df[SCORE_COL] >= cleanup_threshold, ip_col].unique())
            sig_to_ips = df.groupby("signature_id")[ip_col].apply(set).to_dict()
            for sid in list(to_analyze):
                ips = sig_to_ips.get(sid, set())
                # Prune only when ALL the IPs behind the signature are known bad.
                if ips and ips.issubset(known_bad):
                    verdicts[sid] = _pruned_verdict(sid, cleanup_threshold)
                    del to_analyze[sid]

        print(f"Intelligence: Pruned {len(verdicts)} signatures "
              f"(score >= {cleanup_threshold}, no LLM). "
              f"{len(to_analyze)} sent to LLM.")

        # 4. LLM analysis only on the uncertain signatures.
        if to_analyze:
            verdicts.update(analyze_signatures(to_analyze, checkpoint,
                                               model, batch_size))

        merged_df, summary = dataset_analysis(df, verdicts, ip_col=ip_col,
                                              count_column=count_column,
                                              model=model)
    else:
        print("Skipping LLM (use_llm=False)")
        merged_df = df.copy()
        for f in ANALYSIS_FIELDS:
            merged_df[f] = None
        summary = {"summary": "Manual execution (No LLM)"}

    # 5. Export: all original rows/columns + analysis columns.
    output_file = f"{MEDIA_ROOT}/avi_iwaf/waf_llm_processed_file.xlsx"
    with pd.ExcelWriter(output_file) as writer:
        merged_df.to_excel(writer, sheet_name="events", index=False)
        pd.DataFrame([summary]).to_excel(writer, sheet_name="dataset_analysis", index=False)

    # Clean up the checkpoint after a successful full run.
    if use_llm and os.path.exists(checkpoint):
        os.remove(checkpoint)

    return output_file, summary



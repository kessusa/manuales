# -*- coding: utf-8 -*-
"""
WAF LLM Analysis Engine.

Strategy:
  1. DEDUPLICATE : group raw WAF events into unique signatures.
  2. PRUNE       : signatures whose IPs ALL have an AbuseIPDB score >= the
                   cleanup_threshold are classified as 'attack' immediately.
                   The LLM is NEVER called for them; their verdict explicitly
                   states that no LLM was used.
  3. MAP         : analyze the remaining ("uncertain") signatures with the LLM
                   in batches, with checkpointing and adaptive batch size.
  4. REDUCE      : aggregate statistics and export an Excel report that keeps
                   EVERY original row and column plus the analysis columns.
"""

import os
import json
import re
import time
import hashlib

import pandas as pd
import requests
import urllib3

from bookmark.settings import MEDIA_ROOT, LLM_BASE_URL, LLM_MODEL, LLM_API_KEY

# Internal endpoint uses verify=False; silence the InsecureRequestWarning spam.
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BATCH_SIZE = 10                    # default signatures per LLM call
MAX_RETRIES = 3                    # retries per LLM batch
PAYLOAD_TRUNC = 300                # max chars kept from any payload/field
DEFAULT_CLEANUP_THRESHOLD = 10.0   # AbuseIPDB score at/above which an IP is "known bad"
SCORE_COL = "Abuse Confidence Score"

# Message stored in the report for signatures pruned by score (no LLM involved).
PRUNED_NOTE = "Automated verdict: all source IPs have AbuseIPDB score >= {thr}. LLM was NOT used."

ANALYSIS_FIELDS = [
    "classification", "attack_confidence", "false_positive_confidence",
    "risk_level", "attack_type", "security_expert_analysis",
    "evidence_from_log", "why_it_may_be_false_positive", "production_impact",
    "recommended_action", "aviwaf_exception_type", "aviwaf_exception_scope",
    "aviwaf_exception_example", "safe_to_bypass", "code_fix_recommendation",
    "needs_manual_review",
]

SYSTEM_PROMPT = """ROLE
You are a senior cybersecurity analyst specialized in ModSecurity CRS,
AVI/NSX ALB WAF logs and production web application security.

OBJECTIVE
Analyze WAF event signatures. Distinguish real attacks from false positives.
Decide what should be blocked, monitored, or safely bypassed.

OUTPUT FORMAT
Return ONLY a valid JSON array. No markdown, no comments.
One object per input signature, with EXACTLY these fields:
{

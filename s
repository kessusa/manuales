#avi_waf_table th.sticky-col:nth-child(1),
#avi_waf_table td.sticky-col:nth-child(1) {
    position: sticky;
    left: 0;
    width: 60px;
    min-width: 60px;
    max-width: 60px;
    background: #fff;
    z-index: 3;
}

#avi_waf_table th.sticky-col:nth-child(2),
#avi_waf_table td.sticky-col:nth-child(2) {
    position: sticky;
    left: 60px;
    width: 510px;
    min-width: 510px;
    max-width: 510px;
    background: #fff;
    z-index: 3;
}

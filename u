from django.urls import path
from . import views

urlpatterns = [
    # Browse
    path('file_manager/', views.file_manager, name='file_manager'),
    path(
        'file_manager/folder/<int:folder_id>/',
        views.file_manager,
        name='file_manager_folder',
    ),

    # Files
    path(
        'file_manager/download/<int:file_id>/',
        views.download_file,
        name='download_file',
    ),
    path('file_manager/upload/', views.upload_file, name='upload_file'),
    path(
        'file_manager/delete/<int:file_id>/',
        views.delete_file,
        name='delete_file',
    ),

    # Folders
    path('file_manager/create_folder/', views.create_folder, name='create_folder'),
    path(
        'file_manager/delete_folder/<int:folder_id>/',
        views.delete_folder,
        name='delete_folder',
    ),

    # Rename
    path(
        'file_manager/rename_file/<int:file_id>/',
        views.rename_file,
        name='rename_file',
    ),
    path(
        'file_manager/rename_folder/<int:folder_id>/',
        views.rename_folder,
        name='rename_folder',
    ),

    # Move
    path(
        'file_manager/move_file/<int:file_id>/',
        views.move_file,
        name='move_file',
    ),
    path(
        'file_manager/move_folder/<int:folder_id>/',
        views.move_folder,
        name='move_folder',
    ),

    # Permissions
    path(
        'file_manager/permissions/<int:folder_id>/',
        views.folder_permissions,
        name='folder_permissions',
    ),
    path(
        'file_manager/permissions/<int:folder_id>/add/',
        views.add_folder_permission,
        name='add_folder_permission',
    ),
    path(
        'file_manager/permissions/delete/<int:perm_id>/',
        views.delete_folder_permission,
        name='delete_folder_permission',
    ),
]

"""
File manager URL configuration.

Location in project: rss/urls.py
Make sure your project's main urls.py includes these routes, e.g.:
    path('rss/', include('rss.urls', namespace='rss')),
"""
from django.urls import path
from . import views

app_name = 'rss'

urlpatterns = [
    # Root view: lists top-level folders and files
    path('file_manager/', views.file_manager, name='file_manager'),

    # Browse a specific folder by id
    path(
        'file_manager/folder/<int:folder_id>/',
        views.file_manager,
        name='file_manager_folder',
    ),

    # Download a single file
    path(
        'file_manager/download/<int:file_id>/',
        views.download_file,
        name='download_file',
    ),

    # Upload one or multiple files (POST only)
    path('file_manager/upload/', views.upload_file, name='upload_file'),

    # Create a new folder (POST only)
    path('file_manager/create_folder/', views.create_folder, name='create_folder'),

    # Delete a file (POST only)
    path(
        'file_manager/delete/<int:file_id>/',
        views.delete_file,
        name='delete_file',
    ),

    # Delete a folder and its contents (POST only)
    path(
        'file_manager/delete_folder/<int:folder_id>/',
        views.delete_folder,
        name='delete_folder',
    ),
]

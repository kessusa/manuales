"""
Management command to upload a local file into django-filer.

Location in project: rss/management/commands/upload_to_filer.py

Make sure these empty files exist so Django picks up the command:
    rss/management/__init__.py
    rss/management/commands/__init__.py

Usage examples:
    python manage.py upload_to_filer "C:\\reports\\daily.csv" --folder "Firewall APAC Rules"
    python manage.py upload_to_filer "C:\\reports\\daily.csv" --folder "Reports/2026/April"
    python manage.py upload_to_filer "C:\\reports\\daily.csv" --folder "Reports" --replace
"""
from pathlib import Path

from django.core.files import File as DjangoFile
from django.core.management.base import BaseCommand, CommandError

from filer.models import File as FilerFile, Folder


class Command(BaseCommand):
    help = 'Upload a local file into a django-filer folder.'

    def add_arguments(self, parser):
        parser.add_argument(
            'source',
            type=str,
            help='Absolute path to the local file to upload.',
        )
        parser.add_argument(
            '--folder',
            type=str,
            required=True,
            help=(
                'Target folder path inside filer. Use "/" as separator for '
                'nested folders, e.g. "Reports/2026/April". Missing folders '
                'are created automatically.'
            ),
        )
        parser.add_argument(
            '--replace',
            action='store_true',
            help='Replace any existing file with the same name in the target folder.',
        )
        parser.add_argument(
            '--keep-source',
            action='store_true',
            help='Keep the source file on disk after uploading (default: keep it).',
        )
        parser.add_argument(
            '--delete-source',
            action='store_true',
            help='Delete the source file from disk after a successful upload.',
        )

    def handle(self, *args, **options):
        source_path = Path(options['source'])
        folder_path = options['folder']
        replace = options['replace']
        delete_source = options['delete_source']

        # Validate the source file
        if not source_path.is_file():
            raise CommandError(f'Source file does not exist: {source_path}')

        # Resolve (or create) the target folder, supporting nested paths
        target_folder = self._get_or_create_folder(folder_path)

        # Handle a pre-existing file with the same name in the same folder
        existing = FilerFile.objects.filter(
            folder=target_folder,
            original_filename=source_path.name,
        ).first()

        if existing:
            if replace:
                existing.delete()
                self.stdout.write(f'Removed existing file: {source_path.name}')
            else:
                self.stdout.write(self.style.WARNING(
                    f'File "{source_path.name}" already exists in '
                    f'"{folder_path}". Use --replace to overwrite. Skipping.'
                ))
                return

        # Upload into filer
        with source_path.open('rb') as fh:
            FilerFile.objects.create(
                file=DjangoFile(fh, name=source_path.name),
                folder=target_folder,
                original_filename=source_path.name,
            )

        self.stdout.write(self.style.SUCCESS(
            f'Uploaded "{source_path.name}" -> "{folder_path}".'
        ))

        # Optionally remove the source file from disk
        if delete_source:
            try:
                source_path.unlink()
                self.stdout.write(f'Source file deleted: {source_path}')
            except OSError as exc:
                self.stdout.write(self.style.WARNING(
                    f'Could not delete source file: {exc}'
                ))

    @staticmethod
    def _get_or_create_folder(folder_path):
        """
        Resolve a folder path like "A/B/C", creating any missing folders along
        the way. Returns the leaf folder.
        """
        parts = [p.strip() for p in folder_path.split('/') if p.strip()]
        if not parts:
            raise CommandError('Folder path cannot be empty.')

        parent = None
        for part in parts:
            parent, _ = Folder.objects.get_or_create(name=part, parent=parent)
        return parent

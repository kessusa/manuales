const items = $input.all();

return items.map((item) => {
  const raw =
    item.json.text ||
    item.json.output ||
    item.json.response ||
    item.json.message ||
    item.json.content ||
    "";

  let ai;

  try {
    ai = typeof raw === "string" ? JSON.parse(raw) : raw;
  } catch (e) {
    ai = {
      classification: "parse_error",
      attack_confidence: null,
      false_positive_confidence: null,
      risk_level: "unknown",
      security_expert_analysis: raw,
      recommended_action: "Revisar manualmente: la IA no devolvió JSON válido.",
      aviwaf_exception_example: "",
      code_fix_recommendation: ""
    };
  }

  return {
    json: {
      ...item.json,

      classification: ai.classification ?? "",
      attack_confidence: ai.attack_confidence ?? "",
      false_positive_confidence: ai.false_positive_confidence ?? "",
      risk_level: ai.risk_level ?? "",
      security_expert_analysis: ai.security_expert_analysis ?? "",
      recommended_action: ai.recommended_action ?? "",
      aviwaf_exception_example: ai.aviwaf_exception_example ?? "",
      code_fix_recommendation: ai.code_fix_recommendation ?? ""
    }
  };
});

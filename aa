import urllib3
from requests import session

from bookmark.settings import (
    IWAF_API_VERSION,
    HTTP_PROXY,
    IWAF_URL,
    get_iwaf_auth_credentials,
    get_apac_iwaf_auth_credentials, APAC_IWAF_URL
)

urllib3.disable_warnings()


# Diferencias de almacenamiento entre los dos tipos de grupos
GROUPS_KEY = {"pre_crs": "pre_crs_groups", "crs": "crs_overrides"}
RULES_KEY  = {"pre_crs": "rules",          "crs": "rule_overrides"}


class AVIIWAFApi:
    def __init__(self, env='emea'):

        if env == 'emea':
            self.auth_credentials = get_iwaf_auth_credentials()
            self.base_url = IWAF_URL
        else:
            self.auth_credentials = get_apac_iwaf_auth_credentials()
            self.base_url = APAC_IWAF_URL

        self.api_version = IWAF_API_VERSION
        self.http_proxy = HTTP_PROXY

        # Headers
        self.headers = {
            "accept": "application/json",
            "X-Avi-Version": self.api_version,
        }

    def login(self, tenant):
        """Authenticate with the WAF API and return a session object."""
        Session = session()
        Session.verify = False
        Session.headers = self.headers
        Session.auth = self.auth_credentials
        Session.trust_env = False

        # Get CSRF token for session
        login_resp = Session.post(
            f'{self.base_url}/login',
            data={'username': Session.auth[0], 'password': Session.auth[1]}
        )
        csrf = login_resp.cookies.get("csrftoken") or login_resp.headers.get("X-CSRFToken")

        # Update headers with tenant and CSRF token
        Session.headers.update({
            "X-Avi-Tenant": tenant,
            "X-Avi-Version": self.api_version,
            "X-CSRFToken": csrf,
            "accept": "application/json"
        })

        return Session

    def get_data(self):
        with session() as Session:
            Session.verify = False
            Session.headers = self.headers

            Session.auth = self.auth_credentials

            Session.post(f'{self.base_url}/login', data={'username': Session.auth[0], 'password': Session.auth[1]})

            tenant_response = Session.get(f'{self.base_url}/api/tenant?fields=name').json()
            tenant_result = tenant_response['results']

            while tenant_response.get('next'):
                tenant_response = Session.get(tenant_response['next']).json()
                tenant_result.extend(tenant_response['results'])

            result = []
            for instance in tenant_result:
                Session.headers = {
                    "accept": "application/json",
                    "X-Avi-Tenant": instance['name'],
                    "X-Avi-Version": self.api_version
                }

                vs_response = Session.get(f'{self.base_url}/api/virtualservice').json()
                if vs_response.get('results'):
                    for item in vs_response['results']:
                        if 'gslb' in item["name"]:
                            continue

                        # NETWORK SECURITY POLICY
                        nsecurity_policy_response = Session.get(
                            f'{item["network_security_policy_ref"]}').json() if item.get(
                            'network_security_policy_ref') else None

                        # HTTP SECURITY POLICY
                        http_policy_response = Session.get(
                            f'{item["http_policies"][0].get("http_policy_set_ref")}').json() if item.get(
                            'http_policies') and item['http_policies'][0].get('http_policy_set_ref') else None

                        # ERROR PAGE PROFILE
                        error_page_profile_response = Session.get(
                            f'{item["error_page_profile_ref"]}').json() if item.get('error_page_profile_ref') else None

                        # ANALYTICS PROFILE
                        analytics_profile_response = Session.get(f'{item["analytics_profile_ref"]}').json() if item.get(
                            'analytics_profile_ref') else None

                        # WAF POLICY
                        if item.get('waf_policy_ref'):
                            waf_policy_response = Session.get(f'{item["waf_policy_ref"]}').json()
                        else:
                            waf_policy_response = None

                        # WAF CRS
                        waf_crs_response = Session.get(
                            f'{waf_policy_response["waf_crs_ref"]}').json() if waf_policy_response and waf_policy_response.get(
                            'waf_crs_ref') else None

                        # WAF PROFILE
                        waf_profile_response = Session.get(
                            f'{waf_policy_response["waf_profile_ref"]}').json() if waf_policy_response and waf_policy_response.get(
                            'waf_profile_ref') else None

                        # VS IP
                        if item.get('vsvip_ref'):
                            vsvip_response = Session.get(f'{item["vsvip_ref"]}').json()
                            for vip in vsvip_response['vip']:
                                data = {
                                    "tenant": instance['name'],
                                    "vs_name": item["name"],
                                    "vs_ip": vip['ip_address']['addr'],
                                    "vs_status": vip.get('enabled', None),
                                    "services": [str(service["port"]) for service in item["services"]] if item.get(
                                        'services') else None,

                                    "network_security_policy": nsecurity_policy_response["rules"][0][
                                        "name"] if nsecurity_policy_response and nsecurity_policy_response.get(
                                        'rules') else None,

                                    "error_page_profile": error_page_profile_response[
                                        'name'] if error_page_profile_response and error_page_profile_response.get(
                                        'name') else None,

                                    "analytics_profile": analytics_profile_response[
                                        'name'] if analytics_profile_response and analytics_profile_response.get(
                                        'name') else None,

                                    "waf_policy": waf_policy_response[
                                        'name'] if waf_policy_response and waf_policy_response.get('name') else None,

                                    "waf_policy_mode": waf_policy_response[
                                        'mode'] if waf_policy_response and waf_policy_response.get('mode') else None,

                                    "waf_paranoia_level": waf_policy_response[
                                        'paranoia_level'] if waf_policy_response and waf_policy_response.get(
                                        'paranoia_level') else None,

                                    "crs_overrides": waf_policy_response[
                                        'crs_overrides'] if waf_policy_response and waf_policy_response.get(
                                        'crs_overrides') else None,

                                    "waf_crs": waf_crs_response['name'] if waf_crs_response and waf_crs_response.get(
                                        'name') else None,

                                    "waf_profile": waf_profile_response[
                                        'name'] if waf_profile_response and waf_profile_response.get('name') else None,

                                    "http_security": ";".join(
                                        http_policy["name"] for http_policy in http_policy_response[
                                            'http_response_policy']["rules"]
                                    ) if http_policy_response and http_policy_response.get(
                                        'http_response_policy') else None,
                                }
                                result.append(data)

            return result

    ### GROUP OPERATIONS

    def enable_group(self, tenant, policy_name, group_name, group_type="pre_crs"):
        """Enable a group in the WAF policy.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group to enable
            group_type: Type of group ("pre_crs" or "crs")

        Returns:
            True if operation was successful, False otherwise
        """
        return self._modify_group(tenant, policy_name, group_name, group_type, enable=True)

    def disable_group(self, tenant, policy_name, group_name, group_type="pre_crs"):
        """Disable a group in the WAF policy."""
        return self._modify_group(tenant, policy_name, group_name, group_type, enable=False)

    def delete_group(self, tenant, policy_name, group_name, group_type="pre_crs"):
        """Delete a group from the WAF policy."""
        return self._modify_group(tenant, policy_name, group_name, group_type, delete=True)

    ### RULE OPERATIONS

    def enable_rule(self, tenant, policy_name, group_name, rule_id=None, rule_name=None,
                    rule_data=None, group_type="pre_crs"):
        """Enable a rule in a group.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group containing the rule
            rule_id: ID of the rule to enable (for CRS)
            rule_name: Name of the rule to enable (for pre-CRS)
            rule_data: Data for the rule (required when creating a new pre-CRS rule,
                       must include the "rule" field with the SecRule string)
            group_type: Type of group ("pre_crs" or "crs")

        Returns:
            True if operation was successful, False otherwise
        """
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, rule_name=rule_name, rule_data=rule_data, enable=True
        )

    def disable_rule(self, tenant, policy_name, group_name, rule_id=None, rule_name=None,
                     rule_data=None, group_type="pre_crs"):
        """Disable a rule in a group."""
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, rule_name=rule_name, rule_data=rule_data, enable=False
        )

    def delete_rule(self, tenant, policy_name, group_name, rule_id=None, rule_name=None, group_type="pre_crs"):
        """Delete a rule from a group."""
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, rule_name=rule_name, delete=True
        )

    def modify_rule_mode(self, tenant, policy_name, group_name, rule_id, new_mode, group_type="crs"):
        """Modify the mode of a rule in a group.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group containing the rule
            rule_id: ID of the rule to modify
            new_mode: New mode for the rule (e.g., "WAF_MODE_ENFORCEMENT", "WAF_MODE_DETECTION_ONLY")
            group_type: Type of group ("pre_crs" or "crs")

        Returns:
            True if operation was successful, False otherwise
        """
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, rule_data={"mode": new_mode}
        )

    ### EXCLUSION OPERATIONS

    def add_group_exclusion(self, tenant, policy_name, group_name, exclusion_data, group_type="pre_crs"):
        """Add an exclusion to a group.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group to add the exclusion to
            exclusion_data: Data for the exclusion to add
            group_type: Type of group ("pre_crs" or "crs")

        Returns:
            True if operation was successful, False otherwise
        """
        return self._modify_group(
            tenant, policy_name, group_name, group_type, new_exclusion=exclusion_data
        )

    def delete_group_exclusion(self, tenant, policy_name, group_name, exclusion_id, group_type="pre_crs"):
        """Delete an exclusion from a group."""
        return self._modify_group(
            tenant, policy_name, group_name, group_type, exclusion_to_delete=exclusion_id
        )

    def add_rule_exclusion(self, tenant, policy_name, group_name, rule_id, exclusion_data, group_type="crs"):
        """Add an exclusion to a rule."""
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, new_exclusion=exclusion_data
        )

    def delete_rule_exclusion(self, tenant, policy_name, group_name, rule_id, exclusion_id, group_type="crs"):
        """Delete an exclusion from a rule."""
        if group_type == "pre_crs":
            # Pre-CRS rules don't support rule-level exclusions
            print("Pre-CRS rules don't support rule-level exclusions")
            return False
        return self._modify_rule(
            tenant, policy_name, group_name, group_type,
            rule_id=rule_id, exclusion_to_delete=exclusion_id
        )

    ### CORE: UNIFIED GROUP MODIFICATION

    def _modify_group(self, tenant, policy_name, group_name, group_type,
                      enable=None, delete=False, new_exclusion=None, exclusion_to_delete=None):
        """Modify a group in a WAF policy with support for various operations.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group
            group_type: Type of group ("pre_crs" or "crs")
            enable: Enable/disable the group
            delete: Delete the entire group
            new_exclusion: Data for a new exclusion to add
            exclusion_to_delete: ID of the exclusion to delete

        Returns:
            True if operation was successful, False otherwise
        """
        Session = self.login(tenant)

        try:
            # Get the WAF policy
            vs_url = f'{self.base_url}/api/wafpolicy?name={policy_name}'
            vs_get = Session.get(vs_url).json()

            if not vs_get.get("results"):
                print(f"Policy {policy_name} not found.")
                return False

            policy = vs_get["results"][0]
            policy_uuid = policy["uuid"]

            # Get or initialize the groups list
            groups = policy.setdefault(GROUPS_KEY[group_type], [])
            existing_group = self._find_by_name(groups, group_name)

            # Handle different operation types
            if delete:
                if existing_group is None:
                    print(f"Group {group_name} not found, nothing to delete.")
                    return False
                groups.remove(existing_group)
                print(f"Group {group_name} deleted.")

            elif exclusion_to_delete is not None:
                # Delete specific exclusion from the group
                if existing_group and 'exclude_list' in existing_group:
                    if self._delete_exclusion(existing_group['exclude_list'], exclusion_to_delete):
                        print(f"Exclusion {exclusion_to_delete} deleted from group {group_name}.")
                    else:
                        print(f"Exclusion {exclusion_to_delete} not found in group {group_name}.")
                        return False
                else:
                    print(f"No exclusions to delete in group {group_name}.")
                    return False

            else:
                # Create the group if it doesn't exist
                if existing_group is None:
                    if group_type == "crs":
                        # For CRS, validate against the underlying CRS and create override
                        existing_group = self._ensure_crs_override(Session, policy, groups, group_name)
                        if existing_group is None:
                            return False
                    else:
                        existing_group = self._create_group(groups, group_name, group_type)
                        print(f"New {group_type} group {group_name} created.")

                if new_exclusion is not None:
                    # Add a new exclusion to the group
                    if self._add_exclusion(existing_group, new_exclusion):
                        print(f"New exclusion added to group {group_name}.")

                if enable is not None:
                    existing_group["enable"] = enable
                    print(f"Group {group_name} {'enabled' if enable else 'disabled'}.")

            # Reindex all groups to maintain sequential numbering
            self._reindex(groups)

            # Update the policy
            put_url = f'{self.base_url}/api/wafpolicy/{policy_uuid}'
            resp_update = Session.put(put_url, json=policy)

            if resp_update.status_code == 200:
                print("Changes applied successfully.")
                return True
            else:
                print(f"Error updating policy: {resp_update.text}")
                return False

        except Exception as e:
            print(f"Unexpected error: {str(e)}")
            return False

    ### CORE: UNIFIED RULE MODIFICATION

    def _modify_rule(self, tenant, policy_name, group_name, group_type,
                     rule_id=None, rule_name=None,
                     enable=None, delete=False, rule_data=None,
                     new_exclusion=None, exclusion_to_delete=None):
        """Modify a rule in a group with support for various operations.

        Args:
            tenant: Name of the tenant
            policy_name: Name of the WAF policy
            group_name: Name of the group containing the rule
            group_type: Type of group ("pre_crs" or "crs")
            rule_id: ID of the rule to modify (for CRS)
            rule_name: Name of the rule to modify (for pre-CRS)
            enable: Enable/disable the rule
            delete: Delete the entire rule
            rule_data: Data to add/update on the rule
            new_exclusion: Data for a new exclusion to add
            exclusion_to_delete: ID of the exclusion to delete

        Returns:
            True if operation was successful, False otherwise
        """
        if rule_id is None and rule_name is None:
            print("Either rule_id or rule_name is required.")
            return False

        Session = self.login(tenant)

        try:
            # Get the WAF policy
            vs_url = f'{self.base_url}/api/wafpolicy?name={policy_name}'
            vs_get = Session.get(vs_url).json()

            if not vs_get.get("results"):
                print(f"Policy {policy_name} not found.")
                return False

            policy = vs_get["results"][0]
            policy_uuid = policy["uuid"]

            # Get or initialize the groups list
            groups = policy.setdefault(GROUPS_KEY[group_type], [])
            existing_group = self._find_by_name(groups, group_name)

            # Create the group if it doesn't exist
            if existing_group is None:
                if group_type == "crs":
                    # For CRS, validate against the underlying CRS and create override
                    existing_group = self._ensure_crs_override(Session, policy, groups, group_name)
                    if existing_group is None:
                        return False
                else:
                    existing_group = self._create_group(groups, group_name, group_type)
                    print(f"New pre_crs group {group_name} created.")

            # Get or initialize the rules list
            rules = existing_group.setdefault(RULES_KEY[group_type], [])
            existing_rule = self._find_rule(rules, rule_id, rule_name)

            # Handle different operation types
            if delete:
                if existing_rule is None:
                    print(f"Rule {rule_id or rule_name} not found, nothing to delete.")
                    return False
                rules.remove(existing_rule)
                print(f"Rule {rule_id or rule_name} deleted from group {group_name}.")

            elif exclusion_to_delete is not None:
                # Delete specific exclusion from the rule
                if existing_rule and 'exclude_list' in existing_rule:
                    if self._delete_exclusion(existing_rule['exclude_list'], exclusion_to_delete):
                        print(f"Exclusion {exclusion_to_delete} deleted from rule {rule_id or rule_name}.")
                    else:
                        print(f"Exclusion {exclusion_to_delete} not found in rule {rule_id or rule_name}.")
                        return False
                else:
                    print(f"No exclusions to delete in rule {rule_id or rule_name}.")
                    return False

            else:
                # Create the rule if it doesn't exist (only allowed for pre_crs)
                if existing_rule is None:
                    if group_type == "crs":
                        print(f"Rule {rule_id or rule_name} not found in CRS group.")
                        return False
                    existing_rule = self._create_rule(rules, rule_id, rule_name)
                    print(f"New rule {rule_id or rule_name} added to group {group_name}.")

                if rule_data:
                    existing_rule.update(rule_data)
                    print(f"Rule {rule_id or rule_name} updated in group {group_name}.")

                if new_exclusion is not None:
                    if self._add_exclusion(existing_rule, new_exclusion):
                        print(f"New exclusion added to rule {rule_id or rule_name}.")

                if enable is not None:
                    existing_rule["enable"] = enable
                    print(f"Rule {rule_id or rule_name} {'enabled' if enable else 'disabled'}.")

            # Reindex rules to maintain sequential numbering
            self._reindex(rules)

            # Update the policy
            put_url = f'{self.base_url}/api/wafpolicy/{policy_uuid}'
            resp_update = Session.put(put_url, json=policy)

            if resp_update.status_code == 200:
                print("Changes applied successfully.")
                return True
            else:
                print(f"Error updating policy: {resp_update.text}")
                return False

        except Exception as e:
            print(f"Unexpected error: {str(e)}")
            return False

    ### HELPERS

    def _find_by_name(self, items, name):
        """Find an item by name in a list."""
        for item in items:
            if item.get("name") == name:
                return item
        return None

    def _find_rule(self, rules, rule_id, rule_name):
        """Find a rule by rule_id or name in a list of rules."""
        if rule_id is not None:
            for rule in rules:
                if rule.get("rule_id") == rule_id:
                    return rule
        if rule_name is not None:
            for rule in rules:
                if rule.get("name") == rule_name:
                    return rule
        return None

    def _reindex(self, items):
        """Reindex all items to ensure sequential numbering."""
        for index, item in enumerate(items):
            item["index"] = index

    def _create_group(self, groups, group_name, group_type):
        """Create a new group and append it to the groups list."""
        new_group = {
            "enable": True,
            "name": group_name,
            "index": len(groups),
            RULES_KEY[group_type]: []
        }
        groups.append(new_group)
        return new_group

    def _create_rule(self, rules, rule_id, rule_name):
        """Create a new rule and append it to the rules list."""
        new_rule = {
            "enable": True,
            "index": len(rules)
        }
        if rule_id is not None:
            new_rule["rule_id"] = rule_id
        if rule_name is not None:
            new_rule["name"] = rule_name
        rules.append(new_rule)
        return new_rule

    def _ensure_crs_override(self, Session, policy, overrides, group_name):
        """Create a CRS override entry for a group if it exists in the underlying CRS."""
        waf_crs_url = policy.get("waf_crs_ref")
        if not waf_crs_url:
            print(f"Policy has no WAF CRS reference.")
            return None

        waf_crs = Session.get(waf_crs_url).json()
        if not any(g.get("name") == group_name for g in waf_crs.get("groups", [])):
            print(f"CRS group {group_name} not found in WAF CRS.")
            return None

        new_override = {
            "enable": True,
            "name": group_name,
            "index": len(overrides),
            "rule_overrides": []
        }
        overrides.append(new_override)
        print(f"New CRS override created for group {group_name}.")
        return new_override

    def _add_exclusion(self, container, exclusion_data):
        """Add a new exclusion to a group or rule, avoiding duplicates."""
        if 'exclude_list' not in container:
            container['exclude_list'] = []

        # Check if exclusion already exists
        new_id = self._get_exclusion_id(exclusion_data)
        existing_ids = {self._get_exclusion_id(item) for item in container['exclude_list']}

        if new_id in existing_ids:
            print(f"Exclusion already exists: {new_id}")
            return False

        container['exclude_list'].append(exclusion_data)
        return True

    def _delete_exclusion(self, exclude_list, exclusion_id):
        """Delete a specific exclusion from a list by its ID."""
        for i, exclusion in enumerate(exclude_list):
            if self._get_exclusion_id(exclusion) == exclusion_id:
                exclude_list.pop(i)
                return True
        return False

    def _get_exclusion_id(self, exclusion):
        """Generate a unique identifier for an exclusion."""
        if 'rule_id' in exclusion:
            return f"rule_{exclusion['rule_id']}"
        elif 'uri_path' in exclusion:
            return f"uri_{exclusion['uri_path']}"
        elif 'client_subnet' in exclusion:
            return f"ip_{exclusion['client_subnet']['ip_addr']['addr']}"
        return str(hash(frozenset(exclusion.items())))



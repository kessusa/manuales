
const items = $input.all();
const output = [];

for (const item of items) {
  let raw =
    item.json?.response?.generations?.[0]?.[0]?.text ||
    item.json?.output ||
    item.json?.text ||
    item.json?.response ||
    "";

  if (typeof raw !== "string") {
    raw = JSON.stringify(raw);
  }

  raw = raw.trim();

  // Quitar texto antes/después del JSON
  const firstBrace = raw.indexOf("{");
  const lastBrace = raw.lastIndexOf("}");

  if (firstBrace === -1 || lastBrace === -1) {
    throw new Error("No se encontró JSON en la respuesta IA: " + raw);
  }

  raw = raw.slice(firstBrace, lastBrace + 1);

  let parsed;

  try {
    parsed = JSON.parse(raw);
  } catch (error) {
    throw new Error("JSON inválido recibido de la IA: " + raw);
  }

  const rows =
    parsed.per_entry_analysis ||
    parsed.results ||
    parsed.rows ||
    [];

  for (const row of rows) {
    output.push({
      json: row
    });
  }
}

return output;
